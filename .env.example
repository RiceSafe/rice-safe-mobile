# Flutter Environment Variables
# Copy this file to .env and set the correct values

# Base URL for Go backend API (must include /api suffix to match backend routes)
#
# Examples:
# - iOS Simulator / macOS / web (same machine as backend):
#     BASE_URL=http://localhost:8080/api
# - Android Emulator (host machine loopback):
#     BASE_URL=http://10.0.2.2:8080/api
# - Physical device (use your computer's LAN IP, not localhost):
#     BASE_URL=http://192.168.1.10:8080/api
BASE_URL=http://localhost:8080/api

# Set to true (or 1) to skip API: uses JSON-shaped fixtures + DiagnosisBackendParser (same as
# production), mock history list, and keyword "ปกติ/normal/healthy" in description switches to
# healthy fixture. Unset or false to call real POST /diagnosis and GET /diagnosis/history.
# USE_MOCK_DIAGNOSIS=false

# LINE Channel ID
LINE_CHANNEL_ID=your_line_channel_id_here
